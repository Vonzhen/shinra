#!/bin/sh

set -eu

mkdir -p /etc/shinra/runtime
mkdir -p /etc/shinra/rules
mkdir -p /var/run/shinra

chmod 0755 /etc/shinra /etc/shinra/runtime /etc/shinra/rules 2>/dev/null || true
chmod 0755 /var/run/shinra 2>/dev/null || true

chmod 0755 /etc/init.d/shinra 2>/dev/null || true
chmod 0755 /usr/libexec/shinra-ensure-auto-task 2>/dev/null || true
chmod 0755 /usr/libexec/shinra-auto-task 2>/dev/null || true
chmod 0755 /usr/libexec/shinra-runner 2>/dev/null || true
chmod 0755 /usr/libexec/shinra-ruleset-sync-job 2>/dev/null || true

if [ -d /www/shinra ]; then
	chmod 0755 /www/shinra 2>/dev/null || true
fi

if [ -d /www/shinra/zashboard ]; then
	find /www/shinra/zashboard -type d -exec chmod 0755 {} \; 2>/dev/null || true
	find /www/shinra/zashboard -type f -exec chmod 0644 {} \; 2>/dev/null || true
fi

copy_default() {
	local src="$1"
	local dst="$2"

	if [ ! -f "$dst" ] && [ -f "$src" ]; then
		cp "$src" "$dst"
	fi
}

copy_default /usr/share/shinra/profiles/main-profile.json /etc/shinra/main-profile.json
copy_default /usr/share/shinra/defaults/profile-source.json /etc/shinra/profile-source.json
copy_default /usr/share/shinra/defaults/notify.json /etc/shinra/notify.json
copy_default /usr/share/shinra/defaults/zashboard-source.json /etc/shinra/zashboard-source.json
copy_default /usr/share/shinra/defaults/subscriptions.json /etc/shinra/subscriptions.json
copy_default /usr/share/shinra/defaults/node-snapshot.json /etc/shinra/node-snapshot.json

if [ -x /usr/libexec/shinra-ensure-auto-task ]; then
	/usr/libexec/shinra-ensure-auto-task || true
fi

exit 0
