#!/bin/sh

set -u

STATE="/var/run/shinra/job-state.json"
LOCK="/var/run/shinra/ruleset-sync.lock"
TMP="/var/run/shinra/ruleset-sync-result.json"
STATE_TMP="/var/run/shinra/job-state.json.$$"
RUN_DIR="/var/run/shinra"

mkdir -p "$RUN_DIR"

json_escape() {
	printf '%s' "$1" | tr '\r\n\t' '   ' | sed 's/\\/\\\\/g; s/"/\\"/g'
}

now_utc() {
	date -u '+%Y-%m-%dT%H:%M:%SZ'
}

json_file_get() {
	jsonfilter -i "$1" -e "$2" 2>/dev/null || true
}

write_state() {
	local status started finished message required updated unchanged failed checked strategy trace
	status="$1"
	started="$2"
	finished="$3"
	message="$4"
	required="${5:-0}"
	updated="${6:-0}"
	unchanged="${7:-0}"
	failed="${8:-0}"
	checked="${9:-0}"
	strategy="${10:-}"
	trace="${11:-}"

	cat > "$STATE_TMP" <<EOF
{
  "schema_version": 1,
  "jobs": {
    "ruleset_download_required": {
      "task_type": "ruleset_download_required",
      "status": "$(json_escape "$status")",
      "started_at": "$(json_escape "$started")",
      "finished_at": "$(json_escape "$finished")",
      "message": "$(json_escape "$message")",
      "required_count": ${required:-0},
      "completed_count": ${required:-0},
      "updated_count": ${updated:-0},
      "unchanged_count": ${unchanged:-0},
      "failed_count": ${failed:-0},
      "checked_count": ${checked:-0},
      "current_tag": "",
      "current_url_redacted": "",
      "last_error": "",
      "fetch_strategy": "$(json_escape "$strategy")",
      "trace_id": "$(json_escape "$trace")"
    }
  }
}
EOF
	mv "$STATE_TMP" "$STATE"
}

if ! mkdir "$LOCK" 2>/dev/null; then
	exit 0
fi

cleanup() {
	rm -f "$TMP" 2>/dev/null || true
	rm -f "$STATE_TMP" 2>/dev/null || true
	rmdir "$LOCK" 2>/dev/null || true
}

trap cleanup EXIT INT TERM

started_at="$(now_utc)"
write_state "running" "$started_at" "" "Rule Set sync running" 0 0 0 0 0 "" ""
rm -f "$TMP"
ucode -e 'import { ruleset_download_required } from "shinra.ruleset"; import { json_stringify } from "shinra.core.utils"; let result = ruleset_download_required("shinra-ruleset-sync-job", {}); print(json_stringify(result) + "\n");' > "$TMP" 2>&1
code="$?"
finished_at="$(now_utc)"

if [ "$code" != "0" ]; then
	message="$(cat "$TMP" 2>/dev/null || true)"
	write_state "failed" "$started_at" "$finished_at" "ucode failed: $message" 0 0 0 0 0 "" ""
	exit 0
fi

ok="$(json_file_get "$TMP" '@.ok')"
message="$(json_file_get "$TMP" '@.message')"
trace="$(json_file_get "$TMP" '@.trace_id')"
required="$(json_file_get "$TMP" '@.data.required_count')"
updated="$(json_file_get "$TMP" '@.data.updated_count')"
unchanged="$(json_file_get "$TMP" '@.data.unchanged_count')"
failed="$(json_file_get "$TMP" '@.data.failed_count')"
checked="$(json_file_get "$TMP" '@.data.checked_count')"
strategy="$(json_file_get "$TMP" '@.data.fetch_strategy')"

if [ "$ok" = "true" ]; then
	if [ "${failed:-0}" = "0" ]; then
		status="success"
	else
		status="partial"
	fi
	write_state "$status" "$started_at" "$finished_at" "${message:-Required Rule Sets downloaded}" "${required:-0}" "${updated:-0}" "${unchanged:-0}" "${failed:-0}" "${checked:-0}" "$strategy" "$trace"
	exit 0
fi

detail="$(json_file_get "$TMP" '@.detail')"
write_state "failed" "$started_at" "$finished_at" "${detail:-Rule Set sync failed}" "${required:-0}" "${updated:-0}" "${unchanged:-0}" "${failed:-0}" "${checked:-0}" "$strategy" "$trace"
exit 0
