#!/bin/sh

set -u

CONFIG="/etc/shinra/subscriptions.json"
STATE="/var/run/shinra/auto-task.state.json"
LOCK="/var/run/shinra/auto-task.lock"
TMP_DIR="/var/run/shinra"

mkdir -p "$TMP_DIR"

if ! mkdir "$LOCK" 2>/dev/null; then
	echo "shinra-auto-task: already running"
	exit 0
fi

cleanup() {
	rmdir "$LOCK" 2>/dev/null || true
}

trap cleanup EXIT INT TERM

json_get() {
	jsonfilter -i "$CONFIG" -e "$1" 2>/dev/null || true
}

state_get() {
	if [ -f "$STATE" ]; then
		jsonfilter -i "$STATE" -e "$1" 2>/dev/null || true
	fi
}

json_file_get() {
	jsonfilter -i "$1" -e "$2" 2>/dev/null || true
}

normalize_hour() {
	local value
	value="${1:-0}"
	value="$(printf '%s' "$value" | sed 's/^0*//')"
	if [ -z "$value" ]; then
		value="0"
	fi
	printf '%s' "$value"
}

json_escape() {
	printf '%s' "$1" | tr '\r\n\t' '   ' | sed 's/\\/\\\\/g; s/"/\\"/g'
}

job_last() {
	local job field
	job="$1"
	field="$2"
	state_get "@.jobs.${job}.${field}"
}

call_job() {
	local job tmp code ok message status node_count failed_count strategy
	job="$1"
	strategy="${2:-}"
	tmp="${TMP_DIR}/auto-task-${job}.json"
	rm -f "$tmp"

	if [ "$job" = "subscriptions_refresh_auto" ]; then
		case "$strategy" in
			direct|proxy)
				ubus call shinra subscriptions_refresh_auto "{\"strategy\":\"${strategy}\"}" > "$tmp" 2>&1
				;;
			*)
				ubus call shinra subscriptions_refresh_auto > "$tmp" 2>&1
				;;
		esac
	elif [ "$job" = "ruleset_download_required_auto" ]; then
		ubus call shinra ruleset_download_required_auto > "$tmp" 2>&1
	else
		printf '%s\n' "{\"ok\":false,\"message\":\"Unknown job\"}" > "$tmp"
		return 1
	fi

	code="$?"
	if [ "$code" != "0" ]; then
		printf 'fail|ubus failed(%s)\n' "$code"
		return 0
	fi

	ok="$(json_file_get "$tmp" '@.ok')"
	message="$(json_file_get "$tmp" '@.message')"
	[ -n "$message" ] || message="$(json_file_get "$tmp" '@.code')"
	[ -n "$message" ] || message="completed"

	if [ "$ok" != "true" ]; then
		printf 'fail|%s\n' "$message"
		return 0
	fi

	status="success"
	if [ "$job" = "subscriptions_refresh_auto" ]; then
		node_count="$(json_file_get "$tmp" '@.data.node_count')"
		if [ -z "$node_count" ] || [ "$node_count" = "0" ]; then
			status="partial"
		fi
	elif [ "$job" = "ruleset_download_required_auto" ]; then
		failed_count="$(json_file_get "$tmp" '@.data.failed_count')"
		if [ -n "$failed_count" ] && [ "$failed_count" != "0" ]; then
			status="partial"
		fi
	fi

	printf '%s|%s\n' "$status" "$message"
}

write_state() {
	local tmp
	tmp="${STATE}.tmp"

	cat > "$tmp" <<EOF
{
  "schema_version": 1,
  "last_checked_at": "$(json_escape "$checked_at")",
  "current_hour": "$(json_escape "$current_hour")",
  "run_key": "$(json_escape "$run_key")",
  "jobs": {
    "subscriptions_refresh_auto": {
      "enabled": $sub_enabled,
      "scheduled_hour": "$(json_escape "$sub_hour")",
      "due_now": $sub_due,
      "decision": "$(json_escape "$sub_decision")",
      "last_run_key": "$(json_escape "$sub_key")",
      "last_run_at": "$(json_escape "$sub_at")",
      "last_status": "$(json_escape "$sub_status")",
      "last_message": "$(json_escape "$sub_message")"
    },
    "ruleset_download_required_auto": {
      "enabled": $rule_enabled,
      "scheduled_hour": "$(json_escape "$rule_hour")",
      "due_now": $rule_due,
      "decision": "$(json_escape "$rule_decision")",
      "last_run_key": "$(json_escape "$rule_key")",
      "last_run_at": "$(json_escape "$rule_at")",
      "last_status": "$(json_escape "$rule_status")",
      "last_message": "$(json_escape "$rule_message")"
    }
  }
}
EOF

	mv "$tmp" "$STATE"
}

if [ ! -f "$CONFIG" ]; then
	echo "shinra-auto-task: missing $CONFIG"
	exit 0
fi

current_hour="$(normalize_hour "$(date +%H)")"
run_key="$(date +%Y-%m-%dT%H)"
checked_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

sub_enabled_raw="$(json_get '@.subscription_update.auto_update')"
sub_hour="$(normalize_hour "$(json_get '@.subscription_update.update_hour')")"
sub_strategy="$(json_get '@.subscription_update.strategy')"
[ -n "$sub_strategy" ] || sub_strategy="saved"

rule_enabled_raw="$(json_get '@.ruleset.auto_update')"
rule_hour="$(normalize_hour "$(json_get '@.ruleset.update_hour')")"

sub_enabled="false"
rule_enabled="false"
[ "$sub_enabled_raw" = "true" ] && sub_enabled="true"
[ "$rule_enabled_raw" = "true" ] && rule_enabled="true"

sub_due="false"
rule_due="false"
sub_decision="disabled"
rule_decision="disabled"

if [ "$sub_enabled" = "true" ]; then
	sub_decision="waiting"
	if [ "$sub_hour" = "$current_hour" ]; then
		sub_due="true"
		sub_decision="due"
	fi
fi

if [ "$rule_enabled" = "true" ]; then
	rule_decision="waiting"
	if [ "$rule_hour" = "$current_hour" ]; then
		rule_due="true"
		rule_decision="due"
	fi
fi

sub_key="$(job_last subscriptions_refresh_auto last_run_key)"
sub_at="$(job_last subscriptions_refresh_auto last_run_at)"
sub_status="$(job_last subscriptions_refresh_auto last_status)"
sub_message="$(job_last subscriptions_refresh_auto last_message)"

rule_key="$(job_last ruleset_download_required_auto last_run_key)"
rule_at="$(job_last ruleset_download_required_auto last_run_at)"
rule_status="$(job_last ruleset_download_required_auto last_status)"
rule_message="$(job_last ruleset_download_required_auto last_message)"

if [ "$sub_enabled" = "true" ] && [ "$sub_hour" = "$current_hour" ]; then
	if [ "$sub_key" = "$run_key" ]; then
		echo "shinra-auto-task: subscriptions_refresh_auto skipped for $run_key"
		sub_decision="skipped"
	else
		result="$(call_job subscriptions_refresh_auto "$sub_strategy")"
		sub_status="${result%%|*}"
		sub_message="${result#*|}"
		sub_key="$run_key"
		sub_at="$checked_at"
		sub_decision="ran"
		echo "shinra-auto-task: subscriptions_refresh_auto $sub_status"
	fi
fi

if [ "$rule_enabled" = "true" ] && [ "$rule_hour" = "$current_hour" ]; then
	if [ "$rule_key" = "$run_key" ]; then
		echo "shinra-auto-task: ruleset_download_required_auto skipped for $run_key"
		rule_decision="skipped"
	else
		result="$(call_job ruleset_download_required_auto "")"
		rule_status="${result%%|*}"
		rule_message="${result#*|}"
		rule_key="$run_key"
		rule_at="$checked_at"
		rule_decision="ran"
		echo "shinra-auto-task: ruleset_download_required_auto $rule_status"
	fi
fi

write_state

exit 0
