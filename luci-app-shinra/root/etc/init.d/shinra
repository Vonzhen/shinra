#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

SHINRA_CONFIG="/etc/shinra/runtime/config.json"
SHINRA_BIN="/usr/bin/sing-box"

start_service() {
	if [ ! -x "$SHINRA_BIN" ]; then
		echo "sing-box binary not found: $SHINRA_BIN" >&2
		return 1
	fi

	if [ ! -f "$SHINRA_CONFIG" ]; then
		echo "runtime config not found: $SHINRA_CONFIG" >&2
		return 1
	fi

	procd_open_instance shinra
	procd_set_param command "$SHINRA_BIN" run -c "$SHINRA_CONFIG"
	procd_set_param respawn
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger shinra
}
